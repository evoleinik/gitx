#!/usr/bin/env python3
"""gitx — stateless git lane for agents. See README.md."""
import argparse
import base64 as _b64
import json
import os
import posixpath
import subprocess
import sys
import time
from urllib.parse import quote


class GitxError(Exception):
    def __init__(self, code, msg):
        super().__init__(msg)
        self.code = code
        self.msg = msg


def validate_repo_path(path):
    """Return a clean repo-relative POSIX path, or raise GitxError(3)."""
    if path.startswith("/") or os.path.isabs(path):
        raise GitxError(3, f"path must be repo-relative, got absolute: {path!r}")
    norm = posixpath.normpath(path)
    if norm.startswith("..") or norm == "." or norm.startswith("/"):
        raise GitxError(3, f"path escapes repo root: {path!r}")
    return norm


def parse_ref_path(arg):
    """Split '<ref>:<path>' into (ref, repo_path). Path is validated."""
    if ":" not in arg:
        raise GitxError(3, f"expected <ref>:<path>, got {arg!r}")
    ref, _, path = arg.partition(":")
    if not ref or not path:
        raise GitxError(3, f"empty ref or path in {arg!r}")
    return ref, validate_repo_path(path)


COMMIT_MUTATION = """mutation($input: CreateCommitOnBranchInput!) {
  createCommitOnBranch(input: $input) {
    commit { oid url }
  }
}"""


def build_commit_body(repo, branch, message, head_oid, files):
    """Return a GraphQL request body for createCommitOnBranch mutation.

    Args:
        repo: Repository in 'owner/repo' format.
        branch: Branch name.
        message: Commit message (headline).
        head_oid: Expected HEAD OID.
        files: List of (path, bytes) tuples. Contents are base64-encoded.

    Returns:
        Dict with 'query' and 'variables' keys ready for 'gh api graphql --input -'.
    """
    additions = [
        {"path": path, "contents": _b64.b64encode(data).decode("ascii")}
        for path, data in files
    ]
    return {
        "query": COMMIT_MUTATION,
        "variables": {
            "input": {
                "branch": {
                    "repositoryNameWithOwner": repo,
                    "branchName": branch,
                },
                "message": {"headline": message},
                "expectedHeadOid": head_oid,
                "fileChanges": {"additions": additions},
            }
        },
    }


def is_stale_head_error(stderr):
    """Return True if stderr indicates an expected-head-OID mismatch (stale HEAD)."""
    s = stderr.lower()
    return "expected" in s or "is at" in s or "stale" in s


def usage_dir():
    """Return the usage telemetry directory, honoring $GITX_HOME. Creates it if absent."""
    d = os.environ.get("GITX_HOME") or os.path.join(os.path.expanduser("~"), ".gitx")
    os.makedirs(d, exist_ok=True)
    return d


def log_usage(cmd, ok, ms, error):
    """Append one JSON line to usage_dir()/usage.jsonl with telemetry."""
    line = json.dumps({
        "ts": time.strftime("%Y-%m-%dT%H:%M:%S%z"),
        "cmd": cmd,
        "ok": ok,
        "ms": ms,
        "error": error,
    })
    with open(os.path.join(usage_dir(), "usage.jsonl"), "a") as f:
        f.write(line + "\n")


def gh(args, stdin=None):
    proc = subprocess.run(
        ["gh"] + args,
        input=stdin,
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        err = (proc.stderr or "").strip()
        low = err.lower()
        if "auth" in low or "not logged" in low:
            raise GitxError(2, f"gh not authenticated: {err}")
        raise GitxError(1, f"gh {' '.join(args)} failed: {err}")
    return proc.stdout


def resolve_repo(explicit):
    if explicit:
        return explicit
    out = gh(["repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"]).strip()
    if not out:
        raise GitxError(3, "not in a git repo; pass --repo owner/name")
    return out


def repo_default_branch(repo):
    return gh([
        "repo", "view", repo, "--json", "defaultBranchRef",
        "-q", ".defaultBranchRef.name",
    ]).strip()


_REF_QUERY = """query($owner:String!,$name:String!,$qual:String!){
  repository(owner:$owner,name:$name){ ref(qualifiedName:$qual){ target{ oid } } }
}"""


def branch_head_oid(repo, branch):
    owner, name = repo.split("/", 1)
    out = gh([
        "api", "graphql",
        "-f", f"query={_REF_QUERY}",
        "-F", f"owner={owner}", "-F", f"name={name}",
        "-F", f"qual=refs/heads/{branch}",
        "-q", ".data.repository.ref.target.oid",
    ]).strip()
    return out or None


def ensure_branch(repo, branch, from_ref):
    oid = branch_head_oid(repo, branch)
    if oid:
        return oid
    base = from_ref or repo_default_branch(repo)
    base_oid = branch_head_oid(repo, base)
    if not base_oid:
        raise GitxError(3, f"base ref {base!r} not found in {repo}")
    gh([
        "api", "-X", "POST", f"/repos/{repo}/git/refs",
        "-f", f"ref=refs/heads/{branch}",
        "-f", f"sha={base_oid}",
    ])
    return base_oid


def run_commit(repo, branch, message, head_oid, files):
    body = build_commit_body(repo, branch, message, head_oid, files)
    out = gh(["api", "graphql", "--input", "-"], stdin=json.dumps(body))
    data = json.loads(out)["data"]["createCommitOnBranch"]["commit"]
    return {"sha": data["oid"], "url": data["url"]}


def _read_files(paths):
    files = []
    for p in paths:
        repo_path = validate_repo_path(p)
        try:
            with open(p, "rb") as fh:
                data = fh.read()
        except (FileNotFoundError, IsADirectoryError, PermissionError) as e:
            raise GitxError(3, f"cannot read {p}: {e}")
        files.append((repo_path, data))
    return files


def cmd_put(args):
    repo = resolve_repo(args.repo)
    head = ensure_branch(repo, args.branch, args.from_ref)
    files = _read_files(args.paths)
    try:
        commit = run_commit(repo, args.branch, args.message, head, files)
    except GitxError as e:
        if not is_stale_head_error(e.msg):
            raise
        head = branch_head_oid(repo, args.branch)
        try:
            commit = run_commit(repo, args.branch, args.message, head, files)
        except GitxError as e2:
            if is_stale_head_error(e2.msg):
                raise GitxError(4, f"head moved twice under us on {args.branch}; retry")
            raise
    return {
        "sha": commit["sha"],
        "url": commit["url"],
        "branch": args.branch,
        "files": [p for p, _ in files],
    }


def cmd_cat(args):
    ref, path = parse_ref_path(args.ref_path)
    repo = resolve_repo(args.repo)
    try:
        out = gh(["api", f"/repos/{repo}/contents/{path}?ref={quote(ref, safe='')}"])
    except GitxError as e:
        if "404" in e.msg:
            raise GitxError(3, f"{ref}:{path} not found in {repo}")
        raise
    payload = json.loads(out)
    if isinstance(payload, list) or payload.get("type") != "file":
        raise GitxError(3, f"{ref}:{path} is not a file in {repo}")
    content = _decode_blob(repo, ref, path, payload)
    return {
        "ref": ref, "path": path,
        "sha": payload["sha"], "size": payload["size"], "content": content,
    }


def _decode_blob(repo, ref, path, payload):
    """Return the file's text, escalating past the contents API's 1MB cap.

    Above 1MB the contents API returns `encoding: "none"` and an EMPTY content field
    with HTTP 200 — decoding that naively yields "" and reports a real file as empty.
    Escalate to the blobs API (100MB cap) by sha, and refuse binary loudly rather than
    emitting replacement-char mojibake.
    """
    b64 = payload.get("content") or ""
    size = payload.get("size") or 0
    if not b64 and size:
        blob = json.loads(gh(["api", f"/repos/{repo}/git/blobs/{payload['sha']}"]))
        b64 = blob.get("content") or ""
        if not b64:
            raise GitxError(3, f"{ref}:{path} is {size} bytes — too large to fetch "
                               f"(blob API caps at 100MB)")
    raw = _b64.b64decode(b64)
    try:
        return raw.decode("utf-8")
    except UnicodeDecodeError:
        raise GitxError(3, f"{ref}:{path} is binary ({size} bytes); gitx cat serves text. "
                           f"Fetch it with: gh api /repos/{repo}/git/blobs/{payload['sha']}")


def cmd_pr(args):
    repo = resolve_repo(args.repo)
    url = gh([
        "pr", "create", "--repo", repo,
        "--base", args.base, "--head", args.head,
        "--title", args.title, "--body", args.body,
    ]).strip().splitlines()[-1].strip()
    view = json.loads(gh([
        "pr", "view", url, "--repo", repo, "--json", "number,url",
    ]))
    if args.merge:
        gh(["pr", "merge", url, "--repo", repo, "--auto", "--squash"])
    return {"number": view["number"], "url": view["url"]}


def _emit(result, as_json, human):
    if as_json:
        print(json.dumps(result))
    else:
        print(human)


def _print_usage():
    path = os.path.join(usage_dir(), "usage.jsonl")
    if not os.path.exists(path):
        print("no usage yet", file=sys.stderr)
        return 0
    n = ok = 0
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
                n += 1
                ok += 1 if rec.get("ok") else 0
            except (ValueError, KeyError):
                continue
    print(json.dumps({"calls": n, "ok": ok, "fail": n - ok}))
    return 0


class _Parser(argparse.ArgumentParser):
    """Usage errors exit 1 (general), not argparse's default 2 — exit 2 is
    documented to mean gh-not-authed, and a missing --title must not send an
    agent off to run `gh auth login`. Subparsers inherit this class."""

    def error(self, message):
        self.print_usage(sys.stderr)
        print(f"{self.prog}: error: {message}", file=sys.stderr)
        sys.exit(1)


def main(argv=None):
    parser = _Parser(prog="gitx")
    parser.add_argument("--usage", action="store_true", help="print usage stats and exit")
    sub = parser.add_subparsers(dest="cmd")

    p_put = sub.add_parser("put", help="atomic commit of files to a branch")
    p_put.add_argument("branch")
    p_put.add_argument("paths", nargs="+")
    p_put.add_argument("-m", "--message", required=True)
    p_put.add_argument("--repo")
    p_put.add_argument("--from", dest="from_ref")
    p_put.add_argument("--json", action="store_true")

    p_cat = sub.add_parser("cat", help="read a file at a ref")
    p_cat.add_argument("ref_path", metavar="<ref>:<path>")
    p_cat.add_argument("--repo")
    p_cat.add_argument("--json", action="store_true")

    p_pr = sub.add_parser("pr", help="open (and optionally auto-merge) a PR")
    p_pr.add_argument("base")
    p_pr.add_argument("head")
    p_pr.add_argument("--title", required=True)
    p_pr.add_argument("--body", required=True)
    p_pr.add_argument("--merge", action="store_true")
    p_pr.add_argument("--repo")
    p_pr.add_argument("--json", action="store_true")

    args = parser.parse_args(argv)
    if args.usage:
        return _print_usage()
    if not args.cmd:
        parser.print_help()
        return 1

    start = time.time()
    try:
        if args.cmd == "put":
            result = cmd_put(args)
            _emit(result, args.json, f"{result['sha'][:8]} {result['url']}")
        elif args.cmd == "cat":
            result = cmd_cat(args)
            _emit(result, args.json, result["content"])
        elif args.cmd == "pr":
            result = cmd_pr(args)
            _emit(result, args.json, f"#{result['number']} {result['url']}")
        else:
            parser.print_help()
            return 1
        log_usage(args.cmd, True, int((time.time() - start) * 1000), None)
        return 0
    except GitxError as e:
        print(e.msg, file=sys.stderr)
        log_usage(args.cmd, False, int((time.time() - start) * 1000), e.msg)
        return e.code


if __name__ == "__main__":
    sys.exit(main())
