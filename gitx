#!/usr/bin/env python3
"""gitx — stateless git lane for agents. See README.md."""
import base64 as _b64
import json
import os
import posixpath
import time


class GitxError(Exception):
    def __init__(self, code, msg):
        super().__init__(msg)
        self.code = code
        self.msg = msg


def validate_repo_path(path):
    """Return a clean repo-relative POSIX path, or raise GitxError(3)."""
    if path.startswith("/") or os.path.isabs(path):
        raise GitxError(3, f"path must be repo-relative, got absolute: {path!r}")
    norm = posixpath.normpath(path)
    if norm.startswith("..") or norm == "." or norm.startswith("/"):
        raise GitxError(3, f"path escapes repo root: {path!r}")
    return norm


def parse_ref_path(arg):
    """Split '<ref>:<path>' into (ref, repo_path). Path is validated."""
    if ":" not in arg:
        raise GitxError(3, f"expected <ref>:<path>, got {arg!r}")
    ref, _, path = arg.partition(":")
    if not ref or not path:
        raise GitxError(3, f"empty ref or path in {arg!r}")
    return ref, validate_repo_path(path)


COMMIT_MUTATION = """mutation($input: CreateCommitOnBranchInput!) {
  createCommitOnBranch(input: $input) {
    commit { oid url }
  }
}"""


def build_commit_body(repo, branch, message, head_oid, files):
    """Return a GraphQL request body for createCommitOnBranch mutation.

    Args:
        repo: Repository in 'owner/repo' format.
        branch: Branch name.
        message: Commit message (headline).
        head_oid: Expected HEAD OID.
        files: List of (path, bytes) tuples. Contents are base64-encoded.

    Returns:
        Dict with 'query' and 'variables' keys ready for 'gh api graphql --input -'.
    """
    additions = [
        {"path": path, "contents": _b64.b64encode(data).decode("ascii")}
        for path, data in files
    ]
    return {
        "query": COMMIT_MUTATION,
        "variables": {
            "input": {
                "branch": {
                    "repositoryNameWithOwner": repo,
                    "branchName": branch,
                },
                "message": {"headline": message},
                "expectedHeadOid": head_oid,
                "fileChanges": {"additions": additions},
            }
        },
    }


def is_stale_head_error(stderr):
    """Return True if stderr indicates an expected-head-OID mismatch (stale HEAD)."""
    s = stderr.lower()
    return "expected" in s or "is at" in s or "stale" in s


def usage_dir():
    """Return the usage telemetry directory, honoring $GITX_HOME. Creates it if absent."""
    d = os.environ.get("GITX_HOME") or os.path.join(os.path.expanduser("~"), ".gitx")
    os.makedirs(d, exist_ok=True)
    return d


def log_usage(cmd, ok, ms, error):
    """Append one JSON line to usage_dir()/usage.jsonl with telemetry."""
    line = json.dumps({
        "ts": time.strftime("%Y-%m-%dT%H:%M:%S%z"),
        "cmd": cmd,
        "ok": ok,
        "ms": ms,
        "error": error,
    })
    with open(os.path.join(usage_dir(), "usage.jsonl"), "a") as f:
        f.write(line + "\n")
